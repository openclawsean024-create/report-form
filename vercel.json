{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "submit.html",
      "use": "@vercel/static"
    },
    {
      "src": "status.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/submit.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/status.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/submit",
      "dest": "/api/submit.js"
    },
    {
      "src": "/api/status",
      "dest": "/api/status.js"
    },
    {
      "src": "/submit",
      "dest": "/submit.html"
    },
    {
      "src": "/status",
      "dest": "/status.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
